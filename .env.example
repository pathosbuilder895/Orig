# ┌──────────────────────────────────────────────────────────────────┐
# │  Original — Environment Configuration                          │
# │  Copy this file to .env and fill in the values.                │
# │  NEVER commit your .env file to version control.               │
# └──────────────────────────────────────────────────────────────────┘

# ── Application ───────────────────────────────────────────────────
APP_NAME=Original
APP_VERSION=1.0.0
ENVIRONMENT=production          # development | testing | staging | production
DEBUG=false

# ── Security (REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))") ──
SECRET_KEY=CHANGE_ME_GENERATE_A_REAL_SECRET_KEY

# ── Maintenance Backdoor ───────────────────────────────────────────
# Emergency access token for maintenance and debugging. When set, the
# /api/v1/auth/login endpoint accepts this as a password for any username
# and grants admin role. Every use is logged as a WARNING with timestamp
# and IP. Rotate by changing this value + restarting the server.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Leave blank to disable the maintenance backdoor entirely.
MAINTENANCE_TOKEN=CHANGE_ME_GENERATE_A_RANDOM_TOKEN

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://original:CHANGE_ME@localhost:5432/original_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# ── Redis (optional — set ENABLE_REDIS_CACHE=true to activate) ───
REDIS_URL=redis://localhost:6379/0
ENABLE_REDIS_CACHE=false

# ── API / CORS ────────────────────────────────────────────────────
# Comma-separated origins that may call the API (your frontend URL)
_ALLOWED_ORIGINS_STR=https://yourdomain.com
API_V1_PREFIX=/api/v1

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_SCORING=10/minute
RATE_LIMIT_AUTH=5/minute

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_JSON=true                   # true for production JSON, false for dev readability

# ── Scoring Model ─────────────────────────────────────────────────
MODEL_VERSION=1.0.0
MIN_BASELINE_SAMPLES=3
MIN_BASELINE_FOR_ESCALATE=5

# ── First-Run Admin (used only by `python -m original.cli create-admin`) ──
FIRST_ADMIN_EMAIL=admin@yourinstitution.edu
FIRST_ADMIN_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD

# ── Feature Flags ─────────────────────────────────────────────────
ENABLE_BACKGROUND_SCORING=true
ENABLE_METRICS=true

# ── Scoring Pipeline Phases (all default OFF — Phase 1 is always on) ─────────
# Phase 3 — Context manifest resolver (genre, citations, length regime)
CONTEXT_MANIFEST_ENABLED=0
# Phase 5 — Adaptive per-submission weight vector from context manifest
ADAPTIVE_WEIGHTS_ENABLED=0
# Phase 6 — Complex amplitude encoding + quantum fidelity scoring
AMPLITUDE_SCORING_ENABLED=0
# Phase 6 — Adversarial robustness: keyed random unitary projection
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave blank to disable.
SECRET_KEY_UNITARY=
# Phase 6 — Hierarchical Bayesian cold-start prior (blends genre population stats)
BAYESIAN_PRIOR_ENABLED=0
PRIOR_WEIGHT=3.0                # virtual sample count for prior (higher = slower washout)

# ── Local database path (SQLite — dev only, use DATABASE_URL for Postgres) ───
# Relative to project root. Ignored when DATABASE_URL is set.
ORIGINAL_DB=profiles.db

# ── Canvas / LTI 1.3 (leave blank until Canvas integration) ──────
ORIGINAL_BASE_URL=https://yourdomain.com
CANVAS_BASE_URL=
CANVAS_API_TOKEN=
CANVAS_WEBHOOK_SECRET=CHANGE_ME_SET_FROM_CANVAS_ADMIN_WEBHOOK_PAGE
CANVAS_CLIENT_ID=CHANGE_ME_SET_FROM_CANVAS_DEVELOPER_KEYS
LTI_PRIVACY_LEVEL=private

# ── Data Retention ────────────────────────────────────────────────
DEFAULT_RETENTION_DAYS=0        # 0 = no auto-deletion
DEFAULT_INDEX_SUBMISSIONS=false
