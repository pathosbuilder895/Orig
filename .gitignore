# Environment and secrets
.env
.env.local
.env.production

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Testing
.coverage
htmlcov/
.pytest_cache/

# Docker
postgres_data/
redis_data/

# OS
.DS_Store
Thumbs.db

# Databases (local dev only — but allow the pre-baked Render seed DB)
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
!demo/seed.db

# SQLite backups (scripts/backup_db.sh output)
backups/

# Env dev (keep .env.example)
.env.dev

# Pytest temp dirs
pytest-cache-files-*/

# Stray dev log captures (one-off run outputs)
err.log
*.log

# Office app lock files (Word/Excel "~$" temp files)
~$*

# Node
node_modules/

# Claude Code local settings (contains machine-specific absolute paths)
.claude/settings.local.json

# Personal notes / internal comms (not source code)
notes/
standup-*.md
outreach-brief-*.md
content-checkin-*.md
weekly-review-*.md
THIS-WEEK-ACTION-SUMMARY.txt

# Separate product prototype (its own project, not part of Original)
variantexam/

# Bluebook build intermediates (bundle itself IS committed)
demo/bluebook/._bluebook_combined.jsx

# Bluebook Playwright test artifacts (config + specs are tracked; outputs are not)
demo/bluebook/test-results/
demo/bluebook/playwright-report/
demo/bluebook/playwright/.cache/
demo/bluebook/blob-report/

# macOS Finder duplicates (e.g. "file 2.py", "file 3.html")
* 2.*
* 3.*
* 4.*
ORIGINAL_MASTER_ROADMAP.docx
legacy_mvp/

# Benchmark output (generated; not tracked by default — uncomment a dated
# subdirectory to commit a specific evidence run). The README is tracked.
validation/benchmarks/*
!validation/benchmarks/README.md

